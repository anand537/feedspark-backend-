          "mode": "raw",
          "raw": "{\\n    \\\"email\\\": \\\"test@example.com\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth", "login"]
        },
        "description": "Test login without password (should return 400)"
      },
      "response": []
    },
    {
      "name": "ERROR TEST - Invalid User Type",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
