              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n    \\\"name\\\": \\\"Test\\\",\\n    \\\"email\\\": \\\"test@example.com\\\",\\n    \\\"password\\\": \\\"Pass123!@#\\\",\\n    \\\"user_type\\\": \\\"invalid_type\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": ["{{base_url}}"],
          "path": ["auth", "register"]
        },
        "description": "Test registration with invalid user_type (should return 400)"
      },
      "response": []
    }
